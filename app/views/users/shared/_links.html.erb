<%# Invitation-only: no sign-up link. Only login <-> password reset. %>
<div class="mt-6 pt-4 border-t border-olive-100 text-center text-sm text-gray-500 space-y-1">
  <%- if controller_name != "sessions" %>
    <div><%= link_to "Sign in", new_session_path(resource_name), class: "text-olive-500 hover:text-olive-400 font-medium" %></div>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <div><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-olive-500 hover:text-olive-400 font-medium" %></div>
  <% end %>
</div>
