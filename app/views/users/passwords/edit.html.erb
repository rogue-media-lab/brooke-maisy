<h1 class="font-serif text-2xl font-semibold text-gray-900 mb-1">Choose a new password</h1>
<p class="text-sm text-gray-500 mb-6">Enter and confirm your new password below.</p>

<%= render "users/shared/error_messages", resource: resource %>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= f.hidden_field :reset_password_token %>

  <div class="space-y-4">
    <div>
      <%= f.label :password, "New password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-400 mb-1"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password,
            autofocus: true,
            autocomplete: "new-password",
            class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation,
            autocomplete: "new-password",
            class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
    </div>

    <%= f.submit "Change my password",
          class: "w-full rounded-lg bg-olive-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-olive-400 transition-colors cursor-pointer" %>
  </div>
<% end %>

<%= render "users/shared/links" %>
