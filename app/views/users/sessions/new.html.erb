<h1 class="font-serif text-2xl font-semibold text-gray-900 mb-1">Welcome back</h1>
<p class="text-sm text-gray-500 mb-6">Sign in to view your design projects.</p>

<%= render "users/shared/error_messages", resource: resource %>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="space-y-4">
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password,
            autocomplete: "current-password",
            class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-olive-300 text-olive-500 focus:ring-olive-300" %>
        <%= f.label :remember_me, class: "ml-2 text-sm text-gray-600" %>
      </div>
    <% end %>

    <%= f.submit "Sign in",
          class: "w-full rounded-lg bg-olive-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-olive-400 transition-colors cursor-pointer" %>
  </div>
<% end %>

<%= render "users/shared/links" %>
