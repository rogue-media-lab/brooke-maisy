<% content_for(:title, "Your Projects - Brooke & Maisy Interior Designs") %>

<%# Welcome header %>
<section class="bg-cream-50 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl lg:text-4xl font-serif font-semibold text-navy-900 tracking-tight">
      Welcome back<%= ", #{current_user.email.split('@').first.capitalize}" if current_user %>
    </h1>
    <p class="text-gray-600 mt-1">Here are your design projects.</p>
  </div>
</section>

<%# Projects grid %>
<section class="bg-white py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if @projects.any? %>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @projects.each do |project| %>
          <%= render "client/projects/card", project: project %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-olive-100 flex items-center justify-center">
          <svg class="w-7 h-7 text-olive-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <p class="text-navy-900 font-medium">No projects yet</p>
        <p class="text-gray-500 text-sm mt-1">Brooke will set up your project here once you get started.</p>
      </div>
    <% end %>
  </div>
</section>
