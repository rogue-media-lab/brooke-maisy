<div class="rounded-xl border border-theme-100 bg-theme-50 p-5" data-repeatable-room-target="room">
  <% room_number = index.to_s == "__INDEX__" ? "__INDEX__" : index.to_i + 1 %>

  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
    <div>
      <h3 class="font-serif text-xl font-semibold text-theme-500">Room <%= room_number %></h3>
      <p class="text-sm text-gray-500 mt-1">Describe the room's current friction points and desired feeling.</p>
    </div>
    <% if index.to_i.positive? %>
      <button type="button" data-action="repeatable-room#remove"
              class="text-sm font-medium text-red-500 hover:text-red-700 cursor-pointer">
        Remove room
      </button>
    <% end %>
  </div>

  <div class="grid gap-5">
    <%= render "questionnaire_submissions/text_field",
          name: "questionnaire_submission[answers][rooms][#{index}][name]",
          label: "Room name",
          value: questionnaire_room_value(room, "name"),
          placeholder: "Example: Primary bedroom, Kitchen, Home office" %>

    <%= render "questionnaire_submissions/checkbox_group",
          section: "rooms",
          key: "#{index}][functions",
          label: "Primary function",
          options: {
            "Relaxing" => "Relaxing",
            "Work" => "Work",
            "Family time" => "Family time",
            "Entertaining" => "Entertaining",
            "Sleeping" => "Sleeping",
            "Other" => "Other"
          } %>

    <%= render "questionnaire_submissions/checkbox_group",
          section: "rooms",
          key: "#{index}][current_issues",
          label: "Current issues",
          options: {
            "Poor layout" => "Poor layout",
            "Feels cluttered" => "Feels cluttered",
            "Not enough storage" => "Not enough storage",
            "Lighting" => "Lighting",
            "Feels outdated" => "Feels outdated",
            "Not cozy" => "Not cozy",
            "Other" => "Other"
          } %>

    <%= render "questionnaire_submissions/textarea_field",
          name: "questionnaire_submission[answers][rooms][#{index}][must_have_features]",
          label: "Must-have features",
          value: questionnaire_room_value(room, "must_have_features"),
          rows: 3,
          placeholder: "Built-in storage, larger seating area, better task lighting..." %>

    <%= render "questionnaire_submissions/textarea_field",
          name: "questionnaire_submission[answers][rooms][#{index}][desired_atmosphere]",
          label: "Desired atmosphere",
          value: questionnaire_room_value(room, "desired_atmosphere"),
          rows: 3,
          placeholder: "Calm, layered, warm, collected, airy..." %>
  </div>
</div>
