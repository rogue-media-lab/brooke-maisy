<nav class="sticky top-0 z-40 bg-theme-100 border-b border-gray-200" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20">

      <%# Brand - Brooke & Maisy Text Logo %>
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center" do %>
          <%= image_tag "LOGO1.png", alt: "Brooke & Maisy Interior Designs", class: "h-18 w-auto" %>
        <% end %>
      </div>

      <%# Desktop nav links %>
      <div class="hidden sm:flex sm:items-center sm:gap-1">
        <%= link_to "Home", root_path,
              class: "text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
        <%= link_to "About", about_path,
              class: "text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
        <%= link_to "Services", services_path,
              class: "text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
        <%= link_to "Portfolio", portfolio_path,
              class: "text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
        <%= link_to "Contact", contact_path,
              class: "text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
        <%= link_to "Client Portal", client_portal_path,
              class: "text-theme-500 hover:text-theme-400 hover:bg-theme-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>

        <% if user_signed_in? %>
          <span class="text-gray-500 px-3 py-2 text-sm font-medium"><%= current_user.display_name %></span>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_root_path,
                  class: "text-theme-400 hover:text-theme-400 hover:bg-theme-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
          <% end %>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                class: "text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors cursor-pointer" %>
        <% end %>
      </div>

      <%# CTA Button - Book Consultation %>
      <div class="hidden sm:flex sm:items-center">
        <%= link_to "Book Consultation", contact_path,
              class: "bg-theme-500 hover:bg-theme-200 text-white hover:text-theme-500 px-4 py-2 rounded-md text-sm font-medium transition-colors" %>
      </div>

      <%# Mobile menu button %>
      <div class="flex items-center sm:hidden">
        <button data-action="click->navbar#toggle"
                class="text-gray-700 hover:text-gray-900 hover:bg-gray-100 p-2 rounded-md transition-colors"
                aria-label="Toggle navigation menu">

          <svg data-navbar-target="openIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>

          <svg data-navbar-target="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>

        </button>
      </div>

    </div>
  </div>

  <%# Mobile menu (hidden by default) %>
  <div data-navbar-target="menu" class="hidden sm:hidden border-t border-gray-200 bg-gray-50">
    <div class="px-2 py-2 space-y-1">
      <%= link_to "Home", root_path,
            class: "block text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
      <%= link_to "About", about_path,
            class: "block text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
      <%= link_to "Services", services_path,
            class: "block text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
      <%= link_to "Portfolio", portfolio_path,
            class: "block text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
      <%= link_to "Contact", contact_path,
            class: "block text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
      <%= link_to "Client Portal", client_portal_path,
            class: "block text-theme-500 hover:text-theme-500 hover:bg-theme-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>

      <% if user_signed_in? %>
        <div class="px-3 py-2 border-t border-gray-200 mt-1">
          <p class="text-sm font-medium text-gray-900"><%= current_user.display_name %></p>
          <% if current_user.admin? %>
            <%= link_to "Admin", admin_root_path,
                  class: "block text-theme-400 hover:text-theme-500 hover:bg-theme-100 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
          <% end %>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                class: "block text-left text-gray-700 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-md text-sm font-medium transition-colors cursor-pointer bg-transparent border-0 w-full" %>
        </div>
      <% end %>

      <%= link_to "Book Consultation", contact_path,
            class: "block bg-theme-500 hover:bg-theme-200 text-white hover:text-theme-400 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
    </div>
  </div>
</nav>