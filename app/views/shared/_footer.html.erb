<footer class="bg-navy-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">

      <%# Brand Column %>
      <div class="col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-lg font-display font-semibold tracking-wide">
            BROOKE & MAISY
          </span>
        </div>
        <p class="text-gray-400 text-sm mb-2">Tega Cay, SC</p>
        <p class="text-gray-400 text-sm">Serving the Greater Charlotte Area</p>
      </div>

      <%# Navigate Column %>
      <div class="col-span-1">
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4">Navigate</h3>
        <ul class="space-y-2">
          <li><%= link_to "Home", root_path, class: "text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "About", about_path, class: "text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Services", services_path, class: "text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Portfolio", portfolio_path, class: "text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Blog", "#", class: "text-gray-400 hover:text-white transition-colors" %></li>
          <li><%= link_to "Contact", contact_path, class: "text-gray-400 hover:text-white transition-colors" %></li>
        </ul>
      </div>

      <%# Connect Column %>
      <div class="col-span-1">
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4">Connect</h3>
        <ul class="space-y-2">
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Instagram</a></li>
          <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Facebook</a></li>
          <li><a href="mailto:amanda@example.com" class="text-gray-400 hover:text-white transition-colors">Email</a></li>
        </ul>
      </div>

      <%# Contact CTA Column %>
      <div class="col-span-1">
        <h3 class="font-semibold text-sm uppercase tracking-wider mb-4">Let's Talk</h3>
        <p class="text-gray-400 text-sm mb-4">Ready to transform your space? Let's create something beautiful together.</p>
        <%= link_to "Book a Consultation", contact_path,
              class: "inline-block bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors" %>
      </div>

    </div>

    <%# Bottom Bar %>
    <div class="border-t border-gray-800 mt-8 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm">© <%= Time.current.year %> Brooke & Maisy Interior Designs. All rights reserved.</p>
      <p class="text-gray-500 text-sm">EST. 2024</p>
    </div>
  </div>
</footer>