<% content_for(:title, "Invite Client - Admin") %>

<%= link_to admin_clients_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-theme-500 mb-4" do %>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
  All clients
<% end %>

<h1 class="font-serif text-3xl font-semibold text-theme-500 mb-2">Invite a client</h1>
<p class="text-gray-500 mb-6 max-w-lg">We'll create their account and email them a secure link to set their own password. They never need to register themselves.</p>

<div class="bg-white rounded-xl border border-theme-100 p-6 max-w-lg">
  <%= render "form", client: @client, submit_label: "Send invitation" %>
</div>
