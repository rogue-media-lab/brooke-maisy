<% content_for(:title, "Clients - Admin") %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="font-serif text-3xl font-semibold text-theme-500">Clients</h1>
    <p class="text-gray-500 mt-1"><%= pluralize(@clients.size, "client") %></p>
  </div>
  <%= link_to "Invite client", new_admin_client_path,
        class: "bg-theme-500 hover:bg-theme-400 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors" %>
</div>

<div class="bg-white rounded-xl border border-theme-100 overflow-hidden">
  <% if @clients.any? %>
    <div class="grid grid-cols-12 px-5 py-3 bg-theme-100 text-[11px] font-semibold uppercase tracking-wider text-gray-400">
      <div class="col-span-5">Name</div>
      <div class="col-span-5">Email</div>
      <div class="col-span-2 text-right">Projects</div>
    </div>
    <% @clients.each do |client| %>
      <%= link_to admin_client_path(client), class: "grid grid-cols-12 px-5 py-4 items-center border-b border-gray-50 last:border-0 hover:bg-theme-100" do %>
        <div class="col-span-5 font-medium text-theme-500"><%= client.display_name %></div>
        <div class="col-span-5 text-sm text-gray-500 truncate"><%= client.email %></div>
        <div class="col-span-2 text-right text-sm text-gray-600"><%= client.projects.count %></div>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-5 py-12 text-center">
      <p class="text-theme-500 font-medium">No clients yet</p>
      <p class="text-gray-500 text-sm mt-1">Invite your first client to get started.</p>
    </div>
  <% end %>
</div>
