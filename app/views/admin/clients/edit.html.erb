<% content_for(:title, "Edit #{@client.display_name} - Admin") %>

<%= link_to admin_client_path(@client), class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-olive-500 mb-4" do %>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
  Back to client
<% end %>

<h1 class="font-serif text-3xl font-semibold text-navy-900 mb-6">Edit client</h1>

<div class="bg-white rounded-xl border border-olive-100 p-6 max-w-lg">
  <%= render "form", client: @client, submit_label: "Save changes" %>
</div>
