<%= form_with model: [ :admin, project ], class: "space-y-5" do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :user_id, "Client", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :user_id, User.where(role: "client").order(:name), :id, :display_name,
          { prompt: "Select a client" },
          class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none bg-white" %>
  </div>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title,
          class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status, Project.statuses.keys.map { |s| [ s.titleize, s ] },
            {}, class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none bg-white" %>
    </div>
    <div>
      <%= f.label :address, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :address,
            class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
    </div>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4,
          class: "w-full rounded-lg border border-olive-200 px-3 py-2.5 text-sm focus:border-olive-400 focus:ring-2 focus:ring-olive-200 focus:outline-none" %>
  </div>

  <% if project.photos.attached? %>
    <div>
      <span class="block text-sm font-medium text-gray-700 mb-2">Existing photos</span>
      <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
        <% project.photos.each do |photo| %>
          <label class="relative group cursor-pointer rounded-lg border border-olive-200 overflow-hidden bg-gray-50 hover:border-red-300 transition-colors">
            <%= image_tag photo, class: "w-full aspect-square object-cover" %>
            <div class="absolute inset-0 bg-red-500/0 group-hover:bg-red-500/20 transition-colors flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-opacity text-red-600 bg-white/90 rounded-full p-1 shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              </div>
            </div>
            <%= check_box_tag "project[remove_photos][]", photo.signed_id, false, class: "sr-only" %>
          </label>
        <% end %>
      </div>
      <p class="text-xs text-gray-400 mt-1">Click a photo to mark it for removal on save.</p>
    </div>
  <% end %>

  <div>
    <%= f.label :photos, "Add photos", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.file_field :photos, multiple: true, accept: "image/*",
          class: "block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-olive-100 file:text-olive-500 hover:file:bg-olive-200 cursor-pointer" %>
    <p class="text-xs text-gray-400 mt-1">Uploading new photos adds to any existing ones.</p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit submit_label,
          class: "bg-olive-500 hover:bg-olive-400 text-white text-sm font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition-colors" %>
    <%= link_to "Cancel", admin_projects_path, class: "text-sm text-gray-500 hover:text-gray-700 px-3 py-2.5" %>
  </div>
<% end %>
