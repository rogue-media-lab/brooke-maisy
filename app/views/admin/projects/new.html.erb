<% content_for(:title, "New Project - Admin") %>

<%= link_to admin_projects_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-olive-500 mb-4" do %>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
  All projects
<% end %>

<h1 class="font-serif text-3xl font-semibold text-navy-900 mb-6">New project</h1>

<div class="bg-white rounded-xl border border-olive-100 p-6 max-w-2xl">
  <%= render "form", project: @project, submit_label: "Create project" %>
</div>
