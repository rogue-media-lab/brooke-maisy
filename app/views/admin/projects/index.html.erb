<% content_for(:title, "Projects - Admin") %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="font-serif text-3xl font-semibold text-navy-900">Projects</h1>
    <p class="text-gray-500 mt-1"><%= pluralize(@projects.size, "project") %></p>
  </div>
  <%= link_to "New project", new_admin_project_path,
        class: "bg-olive-500 hover:bg-olive-400 text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors" %>
</div>

<%# Status filter pills %>
<div class="flex flex-wrap gap-2 mb-6">
  <%= link_to "All", admin_projects_path,
        class: "px-3 py-1.5 text-xs font-medium rounded-full #{params[:status].blank? ? 'bg-navy-900 text-white' : 'bg-cream-50 border border-olive-100 text-gray-600 hover:bg-olive-100'}" %>
  <% Project.statuses.keys.each do |s| %>
    <%= link_to s.titleize, admin_projects_path(status: s),
          class: "px-3 py-1.5 text-xs font-medium rounded-full #{params[:status] == s ? 'bg-navy-900 text-white' : 'bg-cream-50 border border-olive-100 text-gray-600 hover:bg-olive-100'}" %>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-olive-100 overflow-hidden">
  <% if @projects.any? %>
    <% @projects.each do |project| %>
      <%= link_to admin_project_path(project), class: "flex items-center justify-between px-5 py-4 border-b border-gray-50 last:border-0 hover:bg-cream-50" do %>
        <div class="min-w-0">
          <p class="font-medium text-navy-900 truncate"><%= project.title %></p>
          <p class="text-xs text-gray-400"><%= project.user.display_name %><%= " · #{project.address}" if project.address.present? %></p>
        </div>
        <%= render "admin/shared/status_badge", status: project.status %>
      <% end %>
    <% end %>
  <% else %>
    <div class="px-5 py-12 text-center">
      <p class="text-navy-900 font-medium">No projects<%= " with that status" if params[:status].present? %></p>
      <p class="text-gray-500 text-sm mt-1">Create a project to begin tracking work.</p>
    </div>
  <% end %>
</div>
