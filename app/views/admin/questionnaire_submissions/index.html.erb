<% content_for(:title, "Questionnaires - Brooke & Maisy Admin") %>

<div class="mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-serif text-3xl font-semibold text-theme-500">Questionnaires</h1>
      <p class="text-gray-500 mt-1">Client questionnaire submissions from prospective clients.</p>
    </div>
    <% unread_count = QuestionnaireSubmission.unread.completed.count %>
    <% if unread_count > 0 %>
      <span class="bg-theme-400 text-white text-sm font-medium px-3 py-1 rounded-full">
        <%= pluralize(unread_count, "unread") %></span>
    <% end %>
  </div>
</div>

<% filter_tabs = [
     [ "completed", "Completed", @completed_count ],
     [ "drafts", "Drafts", @draft_count ],
     [ "all", "All", @completed_count + @draft_count ]
   ] %>
<div class="flex items-center gap-2 mb-6">
  <% filter_tabs.each do |key, label, count| %>
    <%= link_to admin_questionnaire_submissions_path(status: key),
          class: "px-3 py-1.5 rounded-full text-sm font-medium transition-colors #{@status_filter == key ? "bg-theme-400 text-white" : "bg-theme-100 text-theme-500 hover:bg-theme-200"}" do %>
      <%= label %> <span class="opacity-70">(<%= count %>)</span>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-theme-100 overflow-hidden">
  <% if @submissions.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="bg-theme-100/50">
          <tr>
            <th class="px-5 py-3 font-medium text-gray-500">Name</th>
            <th class="px-5 py-3 font-medium text-gray-500">Email</th>
            <th class="px-5 py-3 font-medium text-gray-500">Preferred contact</th>
            <th class="px-5 py-3 font-medium text-gray-500">Submitted</th>
            <th class="px-5 py-3 font-medium text-gray-500">Status</th>
            <th class="px-5 py-3 font-medium text-gray-500 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @submissions.each do |submission| %>
            <tr class="hover:bg-theme-100/30 <%= "bg-theme-100/20" unless submission.read? %>">
              <td class="px-5 py-3 font-medium text-theme-500">
                <%= link_to submission.name.presence || "(no name yet)", admin_questionnaire_submission_path(submission), class: "hover:underline" %>
              </td>
              <td class="px-5 py-3 text-gray-600"><%= submission.email %></td>
              <td class="px-5 py-3 text-gray-600"><%= submission.preferred_contact.presence || "—" %></td>
              <td class="px-5 py-3 text-gray-400 whitespace-nowrap"><%= submission.created_at.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-3 whitespace-nowrap">
                <% if submission.draft? %>
                  <span class="text-xs font-medium text-amber-700 bg-amber-100 px-2 py-0.5 rounded-full">Draft</span>
                <% elsif submission.read? %>
                  <span class="text-xs text-gray-400">Read</span>
                <% else %>
                  <span class="text-xs font-medium text-theme-500 bg-theme-200 px-2 py-0.5 rounded-full">New</span>
                <% end %>
              </td>
              <td class="px-5 py-3 text-right">
                <%= button_to "Delete", admin_questionnaire_submission_path(submission), method: :delete,
                      data: { turbo_confirm: "Delete this questionnaire?" },
                      class: "text-xs text-red-500 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-5 py-12 text-center">
      <p class="text-gray-400 text-sm">No questionnaires yet.</p>
    </div>
  <% end %>
</div>
