<% content_for(:title, "Brooke & Maisy Interior Designs - Professional Interior Design in Tega Cay, SC") %>
<% content_for(:description, "Professional interior design services in Tega Cay, SC serving the Greater Charlotte Area. Transform your space into something beautiful.") %>

<%# Hero Section %>
<section class="bg-linear-to-br from-olive-100 to-olive-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center">

      <%# Hero Content %>
      <div class="flex-1">
        <h1 class="text-4xl lg:text-5xl xl:text-6xl font-semibold text-navy-900 leading-tight mb-6" style="letter-spacing: -1.5px;">
          Transform your space into something beautiful
        </h1>
        <p class="text-lg lg:text-xl text-navy-800 leading-relaxed mb-8 max-w-lg">
          Professional interior design services tailored to your lifestyle. Let me help you create a home you'll love coming home to.
        </p>
        <div class="flex flex-wrap gap-4">
          <%= link_to "Start Your Project", contact_path,
                class: "bg-olive-500 hover:bg-pastel-sky hover:text-navy-800 text-white px-6 py-3 rounded-md font-medium transition-colors" %>
          <%= link_to "View Portfolio", portfolio_path,
                class: "border border-navy-900 bg-white text-navy-900 hover:bg-pastel-sky px-6 py-3 rounded-md font-medium transition-colors" %>
        </div>
      </div>

      <%# Hero Image %>
      <div class="flex-1 w-full lg:w-auto">
        <div class="aspect-7/6 rounded-xl border-4 border-olive-300 p-1 bg-olive-400">
          <div class="rounded-lg overflow-hidden bg-gray-200 flex items-center justify-center h-full shadow-[inset_0_0_40px_rgba(0,0,0,0.20)]">
            <%= image_tag "reference/blue-white-living-room.jpg", alt: "Beautiful blue and white living room interior design" %>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%# Stats Section %>
<section class="bg-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap justify-center gap-12 lg:gap-30">

      <div class="text-center">
        <div class="text-5xl font-semibold text-navy-900">50+</div>
        <div class="text-gray-600 mt-1">Projects Completed</div>
      </div>

      <div class="text-center">
        <div class="text-5xl font-semibold text-navy-900">5+</div>
        <div class="text-gray-600 mt-1">Years Experience</div>
      </div>

      <div class="text-center">
        <div class="text-5xl font-semibold text-navy-900">100%</div>
        <div class="text-gray-600 mt-1">Client Satisfaction</div>
      </div>

    </div>
  </div>
</section>

<%# Services Section %>
<section class="bg-cream-100 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl lg:text-4xl font-semibold text-navy-900 mb-12" style="letter-spacing: -1px;">Services</h2>

    <div class="grid md:grid-cols-3 gap-8">

      <div class="bg-white rounded-xl p-8 shadow-sm">
        <div class="w-14 h-14 rounded-lg bg-gray-100 mb-5 flex items-center justify-center">
          <svg class="w-7 h-7 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-navy-900 mb-3">Full Home Redesign</h3>
        <p class="text-gray-600 leading-relaxed">
          Complete transformation of your living spaces with thoughtful layouts, curated furnishings, and cohesive design.
        </p>
      </div>

      <div class="bg-white rounded-xl p-8 shadow-sm">
        <div class="w-14 h-14 rounded-lg bg-gray-100 mb-5 flex items-center justify-center">
          <svg class="w-7 h-7 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-navy-900 mb-3">Room Makeover</h3>
        <p class="text-gray-600 leading-relaxed">
          Focus on a single room to maximize impact. Perfect for updating your living room, bedroom, or kitchen.
        </p>
      </div>

      <div class="bg-white rounded-xl p-8 shadow-sm">
        <div class="w-14 h-14 rounded-lg bg-gray-100 mb-5 flex items-center justify-center">
          <svg class="w-7 h-7 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-navy-900 mb-3">Color & Styling</h3>
        <p class="text-gray-600 leading-relaxed">
          Color consultations, art arrangement, and finishing touches to bring your space to life.
        </p>
      </div>

    </div>
  </div>
</section>

<%# Portfolio Section %>
<section class="bg-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center mb-12">
      <h2 class="text-3xl lg:text-4xl font-semibold text-navy-900" style="letter-spacing: -1px;">Portfolio</h2>
      <%= link_to "View All Projects →", portfolio_path, class: "text-olive-500 font-medium hover:underline" %>
    </div>

    <div class="grid md:grid-cols-3 gap-6">

      <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gray-200 flex items-center justify-center">
        <span class="text-gray-400">[ Project Image ]</span>
      </div>

      <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gray-200 flex items-center justify-center">
        <span class="text-gray-400">[ Project Image ]</span>
      </div>

      <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gray-200 flex items-center justify-center">
        <span class="text-gray-400">[ Project Image ]</span>
      </div>

    </div>
  </div>
</section>


<%# Contact CTA Section %>
<section class="bg-olive-500 text-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl lg:text-4xl font-semibold mb-4" style="letter-spacing: -1px;">Let's create something beautiful</h2>
    <p class="text-white text-lg mb-8 max-w-2xl mx-auto">
      Book a free 30-minute consultation to discuss your project — no pressure, just a conversation about your vision.
    </p>
    <%= link_to "Book a Free Consultation", contact_path,
          class: "inline-block bg-olive-200 hover:bg-olive-100 text-navy-800 px-8 py-4 rounded-md font-medium text-lg transition-colors" %>
  </div>
</section>