<% content_for(:title, "Services - Brooke & Maisy Interior Designs") %>

<section class="bg-theme-100 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl lg:text-5xl font-semibold text-theme-500 mb-4" style="letter-spacing: -1px;">Services</h1>
    <p class="text-xl text-gray-600 mb-12 max-w-2xl">
      Design services for every budget. From a single room refresh to full home renovations — I offer personalized solutions tailored to your needs.
    </p>

    <div class="grid md:grid-cols-3 gap-8 mb-16">

      <div class="bg-white rounded-xl p-8 shadow-sm">
        <div class="w-14 h-14 rounded-lg bg-gray-100 mb-5 flex items-center justify-center">
          <svg class="w-7 h-7 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
