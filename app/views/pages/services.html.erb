<%# FAQ / Not Sure Section %>
<section class="bg-[#FAF9F6] py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-semibold text-theme-500 mb-4" style="letter-spacing: -1px;">Not sure which package fits?</h2>
    <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">
      Let's talk about your project — no pressure, just a conversation about your vision and how we can bring it to life.
    </p>
    <%= link_to "Book a Free Consultation", contact_path,
          class: "inline-block bg-theme-400 hover:bg-theme-500 text-white px-8 py-4 rounded-md font-medium text-lg transition-colors" %>
  </div>
</section>