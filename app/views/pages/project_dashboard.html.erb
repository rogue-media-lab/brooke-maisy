    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl lg:text-4xl font-semibold text-navy-900" style="letter-spacing: -1px;">Project Dashboard</h1>
        <p class="text-gray-600 mt-1">You have 5 active projects</p>
      </div>
      <button class="bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-md font-medium transition-colors">
        + New Project
      </button>
    </div>

    <%# Key Metrics Cards %>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

      <div class="bg-white rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-1">Active Clients</div>
        <div class="text-3xl font-semibold text-navy-900">12</div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-1">In Progress</div>
        <div class="text-3xl font-semibold text-navy-900">5</div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-1">Completed This Month</div>
        <div class="text-3xl font-semibold text-navy-900">2</div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-1">Revenue (MTD)</div>
        <div class="text-3xl font-semibold text-navy-900">$4,250</div>
      </div>

    </div>
  </div>
</section>

