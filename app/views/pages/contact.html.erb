<% content_for(:title, "Contact - Brooke & Maisy Interior Designs") %>

<section class="bg-cream-50 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl lg:text-5xl font-semibold text-navy-900 mb-4" style="letter-spacing: -1px;">Let's Talk</h1>
    <p class="text-xl text-gray-600 mb-12 max-w-2xl">
      Ready to transform your space? Get in touch to schedule your free consultation.
    </p>

    <div class="grid lg:grid-cols-2 gap-12">

      <%# Contact Info %>
      <div>
        <div class="mb-8">
          <h2 class="text-2xl font-semibold text-navy-900 mb-4">Get in Touch</h2>
          <p class="text-gray-600 leading-relaxed">
            I'd love to hear about your project. Whether you're ready to start a full redesign or just want to explore ideas, let's chat.
          </p>
        </div>

        <div class="space-y-6">
          <div>
            <h3 class="font-semibold text-navy-900 mb-1">Location</h3>
            <p class="text-gray-600">Tega Cay, SC</p>
            <p class="text-gray-600">Serving the Greater Charlotte Area</p>
          </div>

          <div>
            <h3 class="font-semibold text-navy-900 mb-1">Email</h3>
            <a href="mailto:amanda@example.com" class="text-emerald-600 hover:underline">amanda@example.com</a>
          </div>

          <div>
            <h3 class="font-semibold text-navy-900 mb-1">Social</h3>
            <div class="flex gap-4">
              <a href="#" class="text-gray-600 hover:text-navy-900">Instagram</a>
              <a href="#" class="text-gray-600 hover:text-navy-900">Facebook</a>
            </div>
          </div>
        </div>
      </div>

      <%# Contact Form %>
      <div class="bg-white rounded-xl p-8 shadow-sm">
        <h2 class="text-2xl font-semibold text-navy-900 mb-6">Send a Message</h2>

        <div id="contact_form">
          <%= form_with url: "#", local: true, class: "space-y-6" do |f| %>
            <div>
              <%= f.label :name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_field :name, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500", placeholder: "Your name" %>
            </div>

            <div>
              <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.email_field :email, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500", placeholder: "your@email.com" %>
            </div>

            <div>
              <%= f.label :phone, "Phone (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.telephone_field :phone, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500", placeholder: "(555) 123-4567" %>
            </div>

            <div>
              <%= f.label :service, "Interested Service", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.select :service, options_for_select(["Full Home Redesign", "Room Makeover", "Color & Styling", "Other"]), { include_blank: "Select a service" }, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
            </div>

            <div>
              <%= f.label :message, "Tell us about your project", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= f.text_area :message, rows: 5, class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500", placeholder: "Describe your space and what you'd like to achieve..." %>
            </div>

            <%= f.submit "Send Message", class: "w-full bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-md font-medium transition-colors" %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</section>