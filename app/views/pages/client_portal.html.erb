<% content_for(:title, "Client Portal - Brooke & Maisy Interior Designs") %>

<%# Welcome Section %>
<section class="bg-cream-50 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-3xl lg:text-4xl font-semibold text-navy-900" style="letter-spacing: -1px;">Welcome back, John</h1>
        <p class="text-gray-600 mt-1">Here's what's happening with your project.</p>
      </div>
      <%= link_to "Message Brooke", "#", 
            class: "bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-md font-medium transition-colors whitespace-nowrap" %>
    </div>
  </div>
</section>

<%# Key Project Overview Cards %>
<section class="bg-white py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-6">

      <%# Card 1: Current Stage %>
      <div class="bg-cream-50 rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-2">Current Stage</div>
        <div class="text-2xl font-semibold text-navy-900">Design Development</div>
        <div class="text-gray-600 mt-1 mb-4">Finalizing material selections</div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-emerald-600 h-2 rounded-full" style="width: 60%;"></div>
        </div>
        <div class="text-xs text-gray-500 mt-2">60% complete</div>
      </div>

      <%# Card 2: Timeline %>
      <div class="bg-cream-50 rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-2">Timeline</div>
        <div class="text-2xl font-semibold text-navy-900">Target: June 15</div>
        <div class="text-gray-600 mt-1">4 weeks until design complete</div>
        <div class="mt-4 flex items-center gap-2 text-gray-500">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-sm">July 17</span>
        </div>
      </div>

      <%# Card 3: Budget %>
      <div class="bg-cream-50 rounded-xl p-6 shadow-sm">
        <div class="text-sm text-gray-500 mb-2">Budget</div>
        <div class="text-2xl font-semibold text-navy-900">$12,500 of $15,000</div>
        <div class="text-gray-600 mt-1">Design fee & selections</div>
        <div class="mt-4 flex items-center gap-2 text-gray-500">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm">$2,500 remaining</span>
        </div>
      </div>

    </div>
  </div>
</section>

<%# Recent Updates Section %>
<section class="bg-cream-50 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-semibold text-navy-900 mb-6">Recent Updates</h2>

    <div class="space-y-4">

      <div class="bg-white rounded-lg p-4 shadow-sm flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-navy-900 font-medium">New paint colors added to your selections</p>
          <p class="text-gray-500 text-sm">Today</p>
        </div>
      </div>

      <div class="bg-white rounded-lg p-4 shadow-sm flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-navy-900 font-medium">Contractor proposal ready for review</p>
          <p class="text-gray-500 text-sm">Yesterday</p>
        </div>
      </div>

      <div class="bg-white rounded-lg p-4 shadow-sm flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-navy-900 font-medium">Message from Brooke: Love the direction we're going!</p>
          <p class="text-gray-500 text-sm">2 days ago</p>
        </div>
      </div>

    </div>
  </div>
</section>

<%# Footer Info %>
<section class="bg-navy-900 text-white py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
      <p class="text-gray-400 text-sm">Logged in as John Doe</p>
      <%= link_to "Sign Out", root_path, class: "text-gray-400 text-sm hover:text-white" %>
    </div>
  </div>
</section>