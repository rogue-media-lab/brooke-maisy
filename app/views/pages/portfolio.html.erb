<% content_for(:title, "Portfolio - Brooke & Maisy Interior Designs") %>

<section class="bg-theme-100 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl lg:text-5xl font-semibold text-theme-500 mb-4" style="letter-spacing: -1px;">Portfolio</h1>
    <p class="text-xl text-gray-600 mb-12 max-w-2xl">
      Recent projects. A collection of our favorite transformations. Each one is unique and designed to fit the your vision and lifestyle.
    </p>

    <% if @projects.any? %>
      <% @projects.each do |project| %>
        <div class="mb-16">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="text-2xl lg:text-3xl font-semibold text-theme-500"><%= project.title %></h2>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-theme-200 text-theme-500">
              <%= project.status.titleize %>
            </span>
          </div>

          <% if project.photos.attached? %>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              <% project.photos.each do |photo| %>
                <div class="aspect-[4/3] rounded-xl overflow-hidden bg-gray-200 relative cursor-pointer hover:opacity-90 transition-opacity group" data-action="click->lightbox#open">
                  <%= image_tag photo, class: "w-full h-full object-cover", alt: "#{project.title} interior design" %>
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-400 italic">No photos uploaded yet for this project.</p>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="text-gray-500 mb-12">No completed projects yet. Check back soon!</p>
    <% end %>

    <%# Reference & Inspiration Gallery %>
