<%# CTA Section %>
<section class="bg-theme-500 text-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl lg:text-4xl font-semibold mb-4" style="letter-spacing: -1px;">Want to see more?</h2>
    <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
      Book a consultation and I can show you more examples
    </p>
    <%= link_to "Book a Consultation", contact_path,
          class: "inline-block bg-theme-400 hover:bg-theme-500 text-white px-8 py-4 rounded-md font-medium text-lg transition-colors" %>
  </div>
</section>
