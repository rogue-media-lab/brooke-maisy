<% content_for(:title, "About - Brooke & Maisy Interior Designs") %>

<section class="bg-theme-100 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl lg:text-5xl font-semibold text-theme-500 mb-8" style="letter-spacing: -1px;">About Brooke & Maisy</h1>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-lg text-gray-600 leading-relaxed mb-6">
          Welcome to Brooke & Maisy Interior Designs, where we believe your home should be a reflection of your personality and lifestyle. With over 5 years of experience in the Greater Charlotte Area, we've helped countless homeowners transform their spaces into beautiful, functional environments.
        </p>
        <p class="text-lg text-gray-600 leading-relaxed mb-6">
          Our approach is simple: we listen to your vision, understand your lifestyle, and create designs that enhance how you live. Whether you're looking for a complete home redesign or a single room makeover, we're here to bring your dream space to life.
        </p>
        <p class="text-lg text-gray-600 leading-relaxed">
          Based in Lake Wylie, SC, we proudly serve the Greater Charlotte Area with professional, personalized interior design services.
        </p>
      </div>
      <div class="aspect-square rounded-xl overflow-hidden bg-gray-200">
        <%= image_tag "amanda-brooke-maisy.jpeg", alt: "Amanda - Brooke & Maisy Interior Designs", class: "w-full h-full object-cover" %>
      </div>
    </div>
  </div>
</section>

<%# Stats Section %>
<section class="bg-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap justify-center gap-12 lg:gap-30">
      <div class="text-center">
        <div class="text-5xl font-semibold text-theme-500">50+</div>
        <div class="text-gray-600 mt-1">Projects Completed</div>
      </div>
      <div class="text-center">
        <div class="text-5xl font-semibold text-theme-500">5+</div>
        <div class="text-gray-600 mt-1">Years Experience</div>
      </div>
      <div class="text-center">
        <div class="text-5xl font-semibold text-theme-500">100%</div>
        <div class="text-gray-600 mt-1">Client Satisfaction</div>
      </div>
    </div>
  </div>
</section>

<%# Contact CTA %>
<section class="bg-theme-500 text-white py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl lg:text-4xl font-semibold mb-4" style="letter-spacing: -1px;">Let's create something beautiful</h2>
    <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
      Book a free 30-minute consultation to discuss your project — no pressure, just a conversation about your vision.
    </p>
    <%= link_to "Book a Free Consultation", contact_path,
          class: "inline-block bg-theme-400 hover:bg-theme-500 text-white px-8 py-4 rounded-md font-medium text-lg transition-colors" %>
  </div>
</section>