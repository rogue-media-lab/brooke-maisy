      <button class="px-4 py-2 bg-emerald-600 text-white rounded-md text-sm font-medium">All (12)</button>
      <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-md text-sm font-medium hover:bg-gray-200">Painters (4)</button>
